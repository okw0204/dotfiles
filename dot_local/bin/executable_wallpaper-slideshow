#!/bin/bash
set -euo pipefail

WALLPAPER_DIR="${WALLPAPER_DIR:-$HOME/ghq/github.com/okw0204/wallpaper}"
INTERVAL_SECONDS="${WALLPAPER_INTERVAL_SECONDS:-600}"
WALLPAPER_SET="${WALLPAPER_SET:-$HOME/.local/bin/wallpaper-set}"

if [[ ! -d $WALLPAPER_DIR ]]; then
  echo "Wallpaper directory not found: $WALLPAPER_DIR" >&2
  exit 1
fi

while true; do
  shopt -s nullglob nocaseglob
  images=("$WALLPAPER_DIR"/*.{jpg,jpeg,png,webp})
  shopt -u nullglob nocaseglob

  if (( ${#images[@]} == 0 )); then
    echo "No wallpaper images found in: $WALLPAPER_DIR" >&2
    sleep 60
    continue
  fi

  image="${images[RANDOM % ${#images[@]}]}"

  "$WALLPAPER_SET" "$image"

  sleep "$INTERVAL_SECONDS" &
  wait $!
done
