#!/bin/bash
set -euo pipefail

WALLPAPER_DIR="${WALLPAPER_DIR:-$HOME/ghq/github.com/okw0204/wallpaper}"
INTERVAL_SECONDS="${WALLPAPER_INTERVAL_SECONDS:-600}"
CURRENT_BACKGROUND_LINK="${CURRENT_BACKGROUND_LINK:-$HOME/.config/omarchy/current/background}"
SCALE_MODE="${WALLPAPER_SCALE_MODE:-fill}"

swaybg_pid=""

stop_swaybg() {
  if [[ -n $swaybg_pid ]] && kill -0 "$swaybg_pid" 2>/dev/null; then
    kill "$swaybg_pid" 2>/dev/null || true
    wait "$swaybg_pid" 2>/dev/null || true
  fi
}

trap 'stop_swaybg; exit 0' INT TERM EXIT

if [[ ! -d $WALLPAPER_DIR ]]; then
  echo "Wallpaper directory not found: $WALLPAPER_DIR" >&2
  exit 1
fi

# Omarchy starts its own swaybg; take ownership once when this service starts.
pkill -x swaybg 2>/dev/null || true

while true; do
  shopt -s nullglob nocaseglob
  images=("$WALLPAPER_DIR"/*.{jpg,jpeg,png,webp})
  shopt -u nullglob nocaseglob

  if (( ${#images[@]} == 0 )); then
    echo "No wallpaper images found in: $WALLPAPER_DIR" >&2
    sleep 60
    continue
  fi

  image="${images[RANDOM % ${#images[@]}]}"

  mkdir -p "$(dirname "$CURRENT_BACKGROUND_LINK")"
  ln -nsf "$image" "$CURRENT_BACKGROUND_LINK"

  stop_swaybg
  swaybg -i "$image" -m "$SCALE_MODE" &
  swaybg_pid=$!

  sleep "$INTERVAL_SECONDS" &
  wait $!
done
