#!/bin/bash

set -euo pipefail

MODE="${1:-paste}"

start_elephant() {
  systemctl --user is-active --quiet elephant.service || systemctl --user start elephant.service
}

launch_walker() {
  walker -m clipboard --width 900 --minheight 300 --maxheight 520
}

notify_message() {
  local message="$1"
  hyprctl notify -1 2500 "rgb(ebb26a)" "$message" >/dev/null 2>&1 || true
}

is_terminal_class() {
  case "$1" in
    Alacritty|kitty|com.mitchellh.ghostty|org.wezfurlong.wezterm|foot|org.gnome.Console|gnome-terminal-server|xterm|XTerm)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

uses_ctrl_v() {
  case "$1" in
    com.mitchellh.ghostty)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

uses_ctrl_shift_v() {
  case "$1" in
    Alacritty|kitty|org.wezfurlong.wezterm|foot|org.gnome.Console|gnome-terminal-server)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

clipboard_fingerprint() {
  local types payload

  types="$(wl-paste --list-types 2>/dev/null | tr '\n' ',' || true)"

  if [[ $types == *"text/plain"* ]]; then
    payload="$(wl-paste --no-newline 2>/dev/null || true)"
  else
    payload="$(wl-paste 2>/dev/null | head -c 4096 || true)"
  fi

  printf '%s\n%s' "$types" "$payload" | sha256sum | cut -d' ' -f1
}

sanitize_label() {
  jq -r '
    .item |
    ((.text // "[non-text item]")
      | gsub("\r"; " ")
      | gsub("\n"; " / ")
      | gsub("\t"; " ")
      | if length > 120 then .[0:117] + "..." else . end) +
    "    " + .subtext
  '
}

select_text_item() {
  local query_output selection_index text_b64
  local -a labels texts preview_types

  query_output="$(elephant query --json 'clipboard;;200;false')"
  [[ -z "$query_output" ]] && return 1

  mapfile -t labels < <(printf '%s\n' "$query_output" | sanitize_label)
  mapfile -t texts < <(printf '%s\n' "$query_output" | jq -r '.item.text // "" | @base64')
  mapfile -t preview_types < <(printf '%s\n' "$query_output" | jq -r '.item.preview_type // ""')

  selection_index="$({ printf '%s\n' "${labels[@]}"; } | walker --dmenu --index -p 'Clipboard' --width 900 --minheight 300 --maxheight 520 || true)"
  [[ -z "$selection_index" ]] && return 1
  [[ "$selection_index" =~ ^[0-9]+$ ]] || return 1

  if [[ "${preview_types[$selection_index]}" != "text" ]]; then
    notify_message 'Clipboard: image/binary item auto-paste is not supported yet'
    return 1
  fi

  text_b64="${texts[$selection_index]}"
  printf '%s' "$text_b64" | base64 -d | wl-copy
}

focus_original_window() {
  local address="$1"

  [[ -z "$address" || "$address" == "null" ]] && return 0

  hyprctl dispatch focuswindow "address:${address}" >/dev/null 2>&1 || true
  sleep 0.05
}

send_paste() {
  local window_class="$1"

  if is_terminal_class "$window_class"; then
    if uses_ctrl_v "$window_class"; then
      hyprctl dispatch sendshortcut "CTRL,V," >/dev/null 2>&1 || true
    elif uses_ctrl_shift_v "$window_class"; then
      hyprctl dispatch sendshortcut "CTRL SHIFT,V," >/dev/null 2>&1 || true
    else
      hyprctl dispatch sendshortcut "SHIFT,Insert," >/dev/null 2>&1 || hyprctl dispatch sendshortcut "SHIFT,INSERT," >/dev/null 2>&1 || true
    fi
  else
    hyprctl dispatch sendshortcut "CTRL,V," >/dev/null 2>&1 || true
  fi
}

main() {
  local active_json address window_class before after

  start_elephant

  active_json="$(hyprctl -j activewindow)"
  address="$(jq -r '.address // empty' <<<"$active_json")"
  window_class="$(jq -r '.class // empty' <<<"$active_json")"
  before="$(clipboard_fingerprint)"

  if [[ "$MODE" == "manage" ]]; then
    launch_walker
    exit 0
  fi

  select_text_item || exit 0

  after="$(clipboard_fingerprint)"
  [[ "$before" != "$after" ]] || exit 0

  sleep 0.12
  focus_original_window "$address"
  sleep 0.08
  send_paste "$window_class"
}

main "$@"
